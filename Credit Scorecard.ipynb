   "metadata": {},
   "source": [
    "## 7. Apply the WOE transform\n",
    "\n",
    "Every raw variable gets a `new_<var>` counterpart holding its WOE value, derived by mapping each\n",
    "observation into the bin it falls into and reading off that bin's WOE.\n",
    "\n",
    "> **Note on `eval`:** the original approach builds a chained ternary expression string (e.g.\n",
    "> `\"0.31 if x <= 5000 else -0.12 if x <= 12000 else ... else 0\"`) and evaluates it with `eval`.\n",
    "> This is unchanged here since it faithfully reproduces the original binning logic, but in a\n",
    "> production pipeline you'd want to replace this with an explicit `pd.cut`/`map` lookup rather than\n",
    "> string-built `eval`, both for safety and clarity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a2f76aef",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df_loan_1.copy()\n",
    "transform_vars_list = [c for c in df.columns if c != \"Late_Loan\"]\n",
    "transform_prefix = \"new_\"\n",
    "\n",
    "for var in transform_vars_list:\n",
    "    small_df = final_iv[final_iv[\"VAR_NAME\"] == var]\n",
    "    transform_dict = dict(zip(small_df.MAX_VALUE, small_df.WOE))\n",
    "\n",
    "    numeric_branches = []\n",
    "    string_branches = []\n",
    "    for max_value, woe in sorted(transform_dict.items()):\n",
    "        numeric_branches.append(f\"{woe} if x <= {max_value} else \")\n",
    "        string_branches.append(f'{woe} if x == \"{max_value}\" else ')\n",
    "\n",
    "    numeric_expr = \"\".join(numeric_branches) + \"0\"\n",
    "    string_expr = \"\".join(string_branches) + \"0\"\n",
    "\n",
    "    if numeric_expr != \"0\":\n",
    "        try:\n",
    "            df[transform_prefix + var] = df[var].apply(lambda x: eval(numeric_expr))\n",
    "        except Exception:\n",
    "            df[transform_prefix + var] = df[var].apply(lambda x: eval(string_expr))\n",
    "\n",
    "df.filter(like=\"new_\").head()"
   ]
  },
