df_loan_1.isnull().sum()
## 5. Weight of Evidence (WOE) and Information Value (IV)

For every predictor we bin its values (quantile bins for numeric variables, one bin per category
for categorical variables) and compute, per bin:

- **WOE** = ln(% of bad loans in bin / % of good loans in bin)
- **IV** = sum over bins of (% bad − % good) × WOE

IV summarizes how predictive a variable is overall; WOE gives a monotonic numeric encoding we can
later substitute in place of the raw value.

> **Fixes applied in this section:**
> - The original code built up output tables with repeated `DataFrame.append` calls inside a loop.
>   `append` was removed entirely in pandas 2.0 — every call below now appends to a list and
>   concatenates once at the end (also the recommended, faster pattern).
> - `pandas.core.algorithms.quantile` was an internal, undocumented function that no longer exists
>   in current pandas — replaced with the public `numpy.quantile`.
> - `scipy.stats.stats` is a deprecated internal alias — replaced with the public `scipy.stats.spearmanr` import.
> - The numeric-vs-categorical check used `np.issubdtype(series.dtype, np.number)`, which raises a
>   `TypeError` on pandas' newer string dtype. Replaced with `pandas.api.types.is_numeric_dtype`,
>   which handles all pandas dtypes correctly.
MAX_BIN = 20
FORCE_BIN = 3


def mono_bin(y: pd.Series, x: pd.Series, n: int = MAX_BIN) -> pd.DataFrame:
    """Bin a numeric predictor `x` against binary target `y` into monotonic WOE buckets."""
    df1 = pd.DataFrame({"X": x, "Y": y})
    justmiss = df1[df1.X.isnull()]
    notmiss = df1[df1.X.notnull()]

    r = 0
    while np.abs(r) < 1 and n > 1:
        try:
            d1 = pd.DataFrame({
                "X": notmiss.X,
                "Y": notmiss.Y,
                "Bucket": pd.qcut(notmiss.X, n, duplicates="drop"),
            })
            d2 = d1.groupby("Bucket", as_index=True)
            r, _ = spearmanr(d2.mean().X, d2.mean().Y)
            n -= 1
        except Exception:
            n -= 1

    if len(d2) == 1:
        n = FORCE_BIN
        bins = np.quantile(notmiss.X, np.linspace(0, 1, n))
        if len(np.unique(bins)) == 2:
            bins = np.insert(bins, 0, 1)
            bins[1] = bins[1] - (bins[1] / 2)
        d1 = pd.DataFrame({
            "X": notmiss.X,
            "Y": notmiss.Y,
            "Bucket": pd.cut(notmiss.X, np.unique(bins), include_lowest=True),
        })
        d2 = d1.groupby("Bucket", as_index=True)

    d3 = pd.DataFrame(index=[])
    d3["MIN_VALUE"] = d2.min().X
    d3["MAX_VALUE"] = d2.max().X
    d3["COUNT"] = d2.count().Y
    d3["EVENT"] = d2.sum().Y
    d3["NONEVENT"] = d2.count().Y - d2.sum().Y
    d3 = d3.reset_index(drop=True)

    if len(justmiss) > 0:
        d4 = pd.DataFrame({"MIN_VALUE": [np.nan]})
        d4["MAX_VALUE"] = np.nan
        d4["COUNT"] = justmiss.Y.count()
        d4["EVENT"] = justmiss.Y.sum()
        d4["NONEVENT"] = justmiss.Y.count() - justmiss.Y.sum()
        d3 = pd.concat([d3, d4], ignore_index=True)

    d3["EVENT_RATE"] = d3.EVENT / d3.COUNT
    d3["NON_EVENT_RATE"] = d3.NONEVENT / d3.COUNT
    d3["DIST_EVENT"] = d3.EVENT / d3.EVENT.sum()
    d3["DIST_NON_EVENT"] = d3.NONEVENT / d3.NONEVENT.sum()
    d3["WOE"] = np.log(d3.DIST_EVENT / d3.DIST_NON_EVENT)
    d3["IV"] = (d3.DIST_EVENT - d3.DIST_NON_EVENT) * d3.WOE
    d3["VAR_NAME"] = "VAR"
    d3 = d3[[
        "VAR_NAME", "MIN_VALUE", "MAX_VALUE", "COUNT", "EVENT", "EVENT_RATE",
        "NONEVENT", "NON_EVENT_RATE", "DIST_EVENT", "DIST_NON_EVENT", "WOE", "IV",
    ]]
    d3 = d3.replace([np.inf, -np.inf], 0)
    d3.IV = d3.IV.sum()
    return d3


def char_bin(y: pd.Series, x: pd.Series) -> pd.DataFrame:
    """Bin a categorical predictor `x` against binary target `y`, one bin per category."""
    df1 = pd.DataFrame({"X": x, "Y": y})
    justmiss = df1[df1.X.isnull()]
    notmiss = df1[df1.X.notnull()]
    df2 = notmiss.groupby("X", as_index=True)

    d3 = pd.DataFrame(index=[])
    d3["COUNT"] = df2.count().Y
    d3["MIN_VALUE"] = df2.sum().Y.index
    d3["MAX_VALUE"] = d3["MIN_VALUE"]
    d3["EVENT"] = df2.sum().Y
    d3["NONEVENT"] = df2.count().Y - df2.sum().Y

    if len(justmiss) > 0:
        d4 = pd.DataFrame({"MIN_VALUE": [np.nan]})
        d4["MAX_VALUE"] = np.nan
        d4["COUNT"] = justmiss.Y.count()
        d4["EVENT"] = justmiss.Y.sum()
        d4["NONEVENT"] = justmiss.Y.count() - justmiss.Y.sum()
        d3 = pd.concat([d3, d4], ignore_index=True)

    d3["EVENT_RATE"] = d3.EVENT / d3.COUNT
    d3["NON_EVENT_RATE"] = d3.NONEVENT / d3.COUNT
    d3["DIST_EVENT"] = d3.EVENT / d3.EVENT.sum()
    d3["DIST_NON_EVENT"] = d3.NONEVENT / d3.NONEVENT.sum()
    d3["WOE"] = np.log(d3.DIST_EVENT / d3.DIST_NON_EVENT)
    d3["IV"] = (d3.DIST_EVENT - d3.DIST_NON_EVENT) * d3.WOE
    d3["VAR_NAME"] = "VAR"
    d3 = d3[[
        "VAR_NAME", "MIN_VALUE", "MAX_VALUE", "COUNT", "EVENT", "EVENT_RATE",
        "NONEVENT", "NON_EVENT_RATE", "DIST_EVENT", "DIST_NON_EVENT", "WOE", "IV",
    ]]
    d3 = d3.replace([np.inf, -np.inf], 0)
    d3.IV = d3.IV.sum()
    return d3.reset_index(drop=True)


def data_vars(df1: pd.DataFrame, target: pd.Series) -> tuple[pd.DataFrame, pd.DataFrame]:
    """Run WOE/IV binning over every column in `df1` except the target itself.

    Returns (per-bin detail table, per-variable IV summary table).
    """
    target_name = target.name
    rows = []

    for col in df1.columns:
        if col == target_name:
            continue
        series = df1[col]
        if pd.api.types.is_numeric_dtype(series) and series.nunique() > 2:
            conv = mono_bin(target, series)
        else:
            conv = char_bin(target, series)
        conv["VAR_NAME"] = col
        rows.append(conv)

    iv_df = pd.concat(rows, ignore_index=True)
    iv = iv_df.groupby("VAR_NAME").IV.max().reset_index()
    return iv_df, iv
final_iv, IV = data_vars(df_loan_1, df_loan_1["Late_Loan"])
final_iv.head()
IV.sort_values("IV")
## 6. Save the IV table (optional)

Update `IV_OUTPUT_PATH` if you'd like to persist the per-variable Information Value summary.
IV_OUTPUT_PATH = "iv_summary.csv"
IV.to_csv(IV_OUTPUT_PATH, index=False)
## 7. Apply the WOE transform

Every raw variable gets a `new_<var>` counterpart holding its WOE value, derived by mapping each
observation into the bin it falls into and reading off that bin's WOE.

> **Note on `eval`:** the original approach builds a chained ternary expression string (e.g.
> `"0.31 if x <= 5000 else -0.12 if x <= 12000 else ... else 0"`) and evaluates it with `eval`.
> This is unchanged here since it faithfully reproduces the original binning logic, but in a
> production pipeline you'd want to replace this with an explicit `pd.cut`/`map` lookup rather than
> string-built `eval`, both for safety and clarity.
df = df_loan_1.copy()
transform_vars_list = [c for c in df.columns if c != "Late_Loan"]
transform_prefix = "new_"

for var in transform_vars_list:
    small_df = final_iv[final_iv["VAR_NAME"] == var]
    transform_dict = dict(zip(small_df.MAX_VALUE, small_df.WOE))

    numeric_branches = []
    string_branches = []
    for max_value, woe in sorted(transform_dict.items()):
        numeric_branches.append(f"{woe} if x <= {max_value} else ")
        string_branches.append(f'{woe} if x == "{max_value}" else ')

    numeric_expr = "".join(numeric_branches) + "0"
    string_expr = "".join(string_branches) + "0"

    if numeric_expr != "0":
        try:
            df[transform_prefix + var] = df[var].apply(lambda x: eval(numeric_expr))
        except Exception:
            df[transform_prefix + var] = df[var].apply(lambda x: eval(string_expr))

df.filter(like="new_").head()
## 8. Sanity-check a transformed variable against the raw one
print(df["new_grade"].value_counts())
print()
print(df["grade"].value_counts())
numeric_cols = df_loan.select_dtypes(include="number").columns
df_loan.groupby("grade")[numeric_cols].mean()
## 9. Fit the model

Select the WOE-transformed features with intuitive, non-leaky signal and fit both a logistic
regression and a decision tree.
y = df["Late_Loan"]
print(f"Base rate: {y.mean():.3%}")

features = [
    "new_addr_state",
    "new_annual_inc",
    "new_delinq_2yrs",
    "new_dti",
    "new_emp_length",
    "new_grade",
    "new_home_ownership",
    "new_inq_last_6mths",
    "new_int_rate",
    "new_issue_d",
    "new_loan_amnt",
    "new_open_acc",
    "new_purpose",
    "new_revol_util",
    "new_term",
]
X = df[features]
import statsmodels.api as sm

logit_model = sm.Logit(y, X)
result = logit_model.fit()
print(result.summary2())
Drop any statistically non-significant variables here based on the summary above before re-fitting, if desired.
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=0)

logreg = LogisticRegression(max_iter=1000)
logreg.fit(X_train, y_train)

dtree = DecisionTreeClassifier(criterion="gini", random_state=100, max_depth=5, min_samples_leaf=5)
dtree.fit(X_train, y_train)
## 10. Evaluate on the held-out test set

> **Fix:** the original notebook predicted with `logreg.predict(X)` — the *full* dataset, including
> the rows the model was trained on — while reporting `.score()` on `X_test`. The confusion matrix
> and classification report were likewise built from predictions on the full dataset rather than
> the held-out test set, which inflates apparent performance with train-set leakage. Every
> evaluation step below now consistently uses `X_test` / `y_test`.
y_pred_logreg = logreg.predict(X_test)
y_pred_tree = dtree.predict(X_test)

print(f"Logistic regression accuracy (test set): {logreg.score(X_test, y_test):.3f}")
print(f"Decision tree accuracy (test set):       {dtree.score(X_test, y_test):.3f}")
print("Logistic regression — confusion matrix (test set)")
print(confusion_matrix(y_test, y_pred_logreg))
print()
print(pd.crosstab(y_test, y_pred_logreg, rownames=["Actual"], colnames=["Predicted"]))
print("Logistic regression — classification report (test set)")
print(classification_report(y_test, y_pred_logreg))
## 11. ROC curves

> **Fix:** the original code called `roc_curve` twice but reused the same `fpr, tpr` variable
> names, so the second call (the decision tree's curve) silently overwrote the first (the logistic
> regression's curve) — the chart ended up plotting the tree's curve twice under two different
> legend labels. Each model now gets its own named `fpr`/`tpr` pair.
logit_roc_auc = roc_auc_score(y_test, logreg.predict_proba(X_test)[:, 1])
tree_roc_auc = roc_auc_score(y_test, dtree.predict_proba(X_test)[:, 1])

fpr_logreg, tpr_logreg, _ = roc_curve(y_test, logreg.predict_proba(X_test)[:, 1])
fpr_tree, tpr_tree, _ = roc_curve(y_test, dtree.predict_proba(X_test)[:, 1])

plt.figure()
plt.plot(fpr_logreg, tpr_logreg, label="Logistic Regression (area = %0.2f)" % logit_roc_auc)
plt.plot(fpr_tree, tpr_tree, label="Decision Tree (area = %0.2f)" % tree_roc_auc)
plt.plot([0, 1], [0, 1], "r--")
plt.xlim([0.0, 1.0])
plt.ylim([0.0, 1.05])
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("Receiver Operating Characteristic")
plt.legend(loc="lower right")
plt.savefig("Log_ROC.png")
